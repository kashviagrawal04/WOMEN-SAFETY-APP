<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <FrameLayout
        android:id="@+id/shieldContainer"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvMarvin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp">

        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/circle_pulse"
            android:alpha="0.15"/>

        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_pulse"
            android:gravity="center"
            android:text="🛡️"
            android:textSize="32sp"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tvMarvin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MARVIN"
        android:textColor="#F0EDEC"
        android:textSize="52sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        app:layout_constraintTop_toBottomOf="@id/shieldContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTagline"/>

    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WHISPER. SAFE."
        android:textColor="#9A7F7A"
        android:textSize="13sp"
        android:letterSpacing="0.3"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvMarvin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvInitializing"/>

    <TextView
        android:id="@+id/tvInitializing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INITIALIZING GUARDIAN..."
        android:textColor="#9A7F7A"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/tvSafeCompanion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSafeCompanion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your silent companion for campus safety\nand peace of mind."
        android:textColor="#9A7F7A"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>