<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:id="@+id/tvBackContacts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← MARVIN"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_weight="1"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTACTS"
            android:textColor="@color/primary_peach"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"/>
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvContactsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Emergency\nCircle"
        android:textColor="@color/text_primary"
        android:textSize="38sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.1"
        android:paddingStart="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvContactCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 in your circle"
        android:textColor="@color/primary_peach"
        android:textSize="10sp"
        android:textStyle="bold"
        android:paddingStart="24dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvContactsTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Contact list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAllContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:clipToPadding="false"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/tvContactCount"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- FAB-style Add button -->
    <Button
        android:id="@+id/btnAddContactFab"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="+ Add Contact"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primary_red"
        android:stateListAnimator="@null"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
