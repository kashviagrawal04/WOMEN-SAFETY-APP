<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MARVIN"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● EMERGENCY ACTIVE"
                android:textColor="@color/primary_peach"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- Pulse Icon -->
        <FrameLayout
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="16dp">

            <View
                android:id="@+id/emergPulse2"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_pulse"
                android:alpha="0.12"/>

            <View
                android:id="@+id/emergPulse1"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_pulse"
                android:alpha="0.22"/>

            <TextView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_sos"
                android:gravity="center"
                android:text="🚨"
                android:textSize="44sp"/>
        </FrameLayout>

        <!-- Alert Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alert sent to"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvAlertCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 closest contacts"
            android:textColor="@color/primary_peach"
            android:textSize="30sp"
            android:textStyle="bold|italic"/>

        <!-- Helpline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞  Calling helpline 1091"
            android:textColor="@color/secondary_orange"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <!-- Alerted Contacts List -->
        <LinearLayout
            android:id="@+id/llAlertedContacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"/>

        <!-- Live Tracking Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_dark"
            android:padding="18dp"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="28sp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE TRACKING"
                    android:textColor="@color/primary_peach"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS Broadcasting Active"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Precise coordinates shared"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Audio Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_dark"
            android:padding="18dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎙️"
                android:textSize="28sp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AUDIO RECORD"
                    android:textColor="@color/primary_peach"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Secure Cloud Upload"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Capturing ambient evidence"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Cancel Button -->
        <Button
            android:id="@+id/btnCancelEmergency"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="Cancel Emergency"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/surface"
            android:layout_marginTop="24dp"
            android:stateListAnimator="@null"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Canceling will immediately notify your guardian network that the situation is under control."
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>
</ScrollView>